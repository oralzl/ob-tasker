{
  "name": "ob-tasker",
  "version": "0.1.1",
  "description": "Project-node task manager for Obsidian.",
  "main": "main.js",
  "scripts": {
    "build": "npm run typecheck && vite build && node scripts/copy-plugin-assets.mjs",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "task"
  ],
  "author": "thiskee",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sortablejs": "^1.15.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/sortablejs": "^1.15.8",
    "obsidian": "^1.7.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
